{% include "common/site-head.njk" %}
<title>Manage Gear - DOC Trailhead</title>
<link rel="stylesheet" href="/static/css/approvals.css">
<link rel="stylesheet" href="/static/css/manage-fleet.css">

{% include "common/site-nav.njk" %}
{% include "common/opo-manage-nav.njk" %}
<main>

<section class="add-vehicle info-card">
<h1>Add Gear</h1>
<form action="/opo/manage-gear" method=post>
  <label for=name>Gear  Name</label>
  <input type=text id=name name=name placeholder="headlamp">
  <label for=gearclass>Gear Class</label>
  <!--TODO: a filter by class?-->
  <select id=gearclass name=gearclass><option>Individual<option>Group </select>

  <label for=type>Gear Type</label>
  <input id=type name=type type=text placeholder="lights">

  <label for=quantity>Gear Quantity</label>
  <input id=quantity name=quantity type=number value=1 min=1>
  <button class="action approve">Add</button>
</form>
</section>

<section class="fleet info-card">
<h1>Gear</h1>
<div class=trip-table-overflow-wrapper>
<table class=trip-table>
<thead><tr><th>Name<th>Class<th>Type<th>Quantity<th>
<tbody>
{% for requested_gear in gear %}
  <tr>
    <td>{{ requested_gear.name }}
    <td>{{ requested_gear.class }}
    <td>{{ requested_gear.type }}
    <td>{{ requested_gear.quantity }}
    <td><button
        class="action deny"
        hx-confirm="Delete {{ gear.name }} from list?"
        hx-delete="/opo/manage-gear/{{ requested_gear.id }}"
        hx-target="closest tr"
        hx-swap="outerHTML swap:.7s"
      >Delete</button>
  </tr>
{% endfor %}
</table>
</div>
</section>

</main>

